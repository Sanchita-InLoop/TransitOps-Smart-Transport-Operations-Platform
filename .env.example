# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database (raw pg pool, matching the TransitOps PostgreSQL DDL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/transitops

# --- Auth ---
# Use a long, random, high-entropy secret in production (never commit real value).
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=8h

# --- bcrypt ---
BCRYPT_SALT_ROUNDS=12
